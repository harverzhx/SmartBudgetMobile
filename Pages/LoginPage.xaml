<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBudgetMobile.Pages.LoginPage"
             Title="Login"
             BackgroundColor="#F0F2F5">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="15" VerticalOptions="Center">

            <Label Text="SmartBudget"
                   FontSize="28" FontAttributes="Bold"
                   HorizontalTextAlignment="Center"
                   TextColor="#2C3E50" />

            <Label Text="Budget Management System"
                   FontSize="14"
                   HorizontalTextAlignment="Center"
                   TextColor="#7F8C8D"
                   Margin="0,0,0,20" />

            <Frame BackgroundColor="White" CornerRadius="10" Padding="20" HasShadow="True">
                <VerticalStackLayout Spacing="12">

                    <Label Text="Login" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" />

                    <Entry x:Name="txtUsername" Placeholder="Username"
                           BackgroundColor="#F9F9F9" />

                    <Entry x:Name="txtPassword" Placeholder="Password"
                           IsPassword="True" BackgroundColor="#F9F9F9" />

                    <Label x:Name="lblError" TextColor="#E74C3C" FontSize="12" IsVisible="False" />

                    <Button x:Name="btnLogin" Text="Login"
                            BackgroundColor="#3498DB" TextColor="White"
                            FontAttributes="Bold" HeightRequest="45"
                            Clicked="OnLoginClicked" />

                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Button Text="Create Account" BackgroundColor="Transparent"
                                TextColor="#3498DB" FontSize="12"
                                Clicked="OnRegisterClicked" />
                        <Button Text="Forgot Password" BackgroundColor="Transparent"
                                TextColor="#7F8C8D" FontSize="12"
                                Clicked="OnForgotPasswordClicked" />
                    </HorizontalStackLayout>

                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
