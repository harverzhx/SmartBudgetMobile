<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBudgetMobile.Pages.DashboardPage"
             Title="Dashboard"
             BackgroundColor="#F0F2F5">

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="10">

            <Label x:Name="lblWelcome" Text="Welcome!"
                   FontSize="22" FontAttributes="Bold" TextColor="#2C3E50" />

            <!-- Summary Cards -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                <Frame Grid.Row="0" Grid.Column="0" BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout>
                        <Label x:Name="lblAllowance" Text="₱0" FontSize="18" FontAttributes="Bold" TextColor="#2ECC71" />
                        <Label Text="Allowance" FontSize="11" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="0" Grid.Column="1" BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout>
                        <Label x:Name="lblExpenses" Text="₱0" FontSize="18" FontAttributes="Bold" TextColor="#E74C3C" />
                        <Label Text="Expenses" FontSize="11" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="0" BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout>
                        <Label x:Name="lblBalance" Text="₱0" FontSize="18" FontAttributes="Bold" TextColor="#3498DB" />
                        <Label Text="Balance" FontSize="11" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="1" Grid.Column="1" BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout>
                        <Label x:Name="lblMonthly" Text="₱0" FontSize="18" FontAttributes="Bold" TextColor="#9B59B6" />
                        <Label Text="This Month" FontSize="11" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="0" BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout>
                        <Label x:Name="lblWeekly" Text="₱0" FontSize="18" FontAttributes="Bold" TextColor="#2C3E50" />
                        <Label Text="This Week" FontSize="11" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Frame>

                <Frame Grid.Row="2" Grid.Column="1" BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                    <VerticalStackLayout>
                        <Label x:Name="lblToday" Text="₱0" FontSize="18" FontAttributes="Bold" TextColor="#F39C12" />
                        <Label Text="Today" FontSize="11" TextColor="#7F8C8D" />
                    </VerticalStackLayout>
                </Frame>

            </Grid>

            <!-- Menu Buttons -->
            <Label Text="Quick Access" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,10,0,0" />

            <Button Text="Expenses" BackgroundColor="#3498DB" TextColor="White"
                    FontAttributes="Bold" HeightRequest="50" CornerRadius="10"
                    Clicked="OnExpensesClicked" />
            <Button Text="Budget" BackgroundColor="#2ECC71" TextColor="White"
                    FontAttributes="Bold" HeightRequest="50" CornerRadius="10"
                    Clicked="OnBudgetClicked" />
            <Button Text="Bills" BackgroundColor="#E67E22" TextColor="White"
                    FontAttributes="Bold" HeightRequest="50" CornerRadius="10"
                    Clicked="OnBillsClicked" />
            <Button Text="Savings" BackgroundColor="#9B59B6" TextColor="White"
                    FontAttributes="Bold" HeightRequest="50" CornerRadius="10"
                    Clicked="OnSavingsClicked" />
            <Button Text="Allowance" BackgroundColor="#2ECC71" TextColor="White"
                    FontAttributes="Bold" HeightRequest="50" CornerRadius="10"
                    Clicked="OnAllowanceClicked" />
            <Button Text="Settings" BackgroundColor="#95A5A6" TextColor="White"
                    FontAttributes="Bold" HeightRequest="50" CornerRadius="10"
                    Clicked="OnSettingsClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
