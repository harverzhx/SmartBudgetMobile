<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SmartBudgetMobile.Pages.ExpensesPage"
             Title="Expenses"
             BackgroundColor="#F0F2F5">
    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="10">
            <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Entry x:Name="txtSearch" Placeholder="Search expenses..." BackgroundColor="#F9F9F9" TextChanged="OnSearchChanged" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Picker x:Name="pickerFilter" Title="Filter" SelectedIndexChanged="OnFilterChanged">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>All</x:String>
                                    <x:String>Today</x:String>
                                    <x:String>This Week</x:String>
                                    <x:String>This Month</x:String>
                                    <x:String>This Year</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                        <Picker x:Name="pickerMonth" Title="Month" IsVisible="False" SelectedIndexChanged="OnMonthChanged" Grid.Column="1">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>All</x:String>
                                    <x:String>January</x:String><x:String>February</x:String><x:String>March</x:String>
                                    <x:String>April</x:String><x:String>May</x:String><x:String>June</x:String>
                                    <x:String>July</x:String><x:String>August</x:String><x:String>September</x:String>
                                    <x:String>October</x:String><x:String>November</x:String><x:String>December</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            <Frame BackgroundColor="White" CornerRadius="10" Padding="15" HasShadow="True">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Expense Details" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" />
                    <Entry x:Name="txtExpenseName" Placeholder="Expense name" BackgroundColor="#F9F9F9" />
                    <Picker x:Name="pickerCategory" Title="Select category" BackgroundColor="#F9F9F9" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry x:Name="txtQuantity" Placeholder="Qty" Keyboard="Numeric" BackgroundColor="#F9F9F9" TextChanged="OnQtyOrPriceChanged" />
                        <Picker x:Name="pickerUnit" Title="Unit" BackgroundColor="#F9F9F9" Grid.Column="1" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                        <Entry x:Name="txtPricePerUnit" Placeholder="Price/unit" Keyboard="Numeric" BackgroundColor="#F9F9F9" TextChanged="OnQtyOrPriceChanged" />
                        <Entry x:Name="txtAmount" Placeholder="Amount" Keyboard="Numeric" BackgroundColor="#E8F0FE" IsReadOnly="True" Grid.Column="1" />
                    </Grid>
                    <DatePicker x:Name="datePicker" MinimumDate="2020-01-01" MaximumDate="2030-12-31" />
                    <Entry x:Name="txtNotes" Placeholder="Notes (optional)" BackgroundColor="#F9F9F9" />
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="5">
                        <Button x:Name="btnAdd" Text="Add" BackgroundColor="#2ECC71" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="8" Clicked="OnAddClicked" />
                        <Button x:Name="btnUpdate" Text="Update" BackgroundColor="#3498DB" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="8" IsEnabled="False" Clicked="OnUpdateClicked" Grid.Column="1" />
                        <Button x:Name="btnDelete" Text="Delete" BackgroundColor="#E74C3C" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="8" IsEnabled="False" Clicked="OnDeleteClicked" Grid.Column="2" />
                        <Button Text="Reset" BackgroundColor="#95A5A6" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="8" Clicked="OnResetClicked" Grid.Column="3" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>
            <Label Text="Expenses List" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" />
            <CollectionView x:Name="expensesList" SelectionMode="Single" SelectionChanged="OnExpenseSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="White" CornerRadius="8" Padding="12" Margin="0,3" HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto">
                                <Label Text="{Binding ExpenseName}" FontSize="15" FontAttributes="Bold" TextColor="#2C3E50" />
                                <Label Text="{Binding Amount, StringFormat='{0:C}'}" FontSize="15" FontAttributes="Bold" TextColor="#E74C3C" Grid.Column="1" />
                                <Label Text="{Binding Category}" FontSize="12" TextColor="#7F8C8D" Grid.Row="1" />
                                <Label Text="{Binding Date, StringFormat='{0:MMM dd, yyyy}'}" FontSize="12" TextColor="#7F8C8D" Grid.Row="1" Grid.Column="1" />
                                <Label Text="{Binding Notes}" FontSize="11" TextColor="#95A5A6" Grid.Row="2" Grid.ColumnSpan="2" LineBreakMode="TailTruncation" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No expenses found" HorizontalTextAlignment="Center" TextColor="#95A5A6" Margin="0,20" />
                </CollectionView.EmptyView>
            </CollectionView>
            <Label Text="Templates" FontSize="16" FontAttributes="Bold" TextColor="#2C3E50" Margin="0,10,0,0" />
            <CollectionView x:Name="templatesList" SelectionMode="Single" SelectionChanged="OnTemplateSelected">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="#F8F9FA" CornerRadius="8" Padding="12" Margin="0,3" HasShadow="True">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Text="{Binding TemplateName}" FontSize="14" FontAttributes="Bold" TextColor="#8E44AD" />
                                <Label Text="{Binding Category}" FontSize="12" TextColor="#7F8C8D" Grid.Column="1" />
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
                <CollectionView.EmptyView>
                    <Label Text="No templates saved" HorizontalTextAlignment="Center" TextColor="#95A5A6" Margin="0,10" />
                </CollectionView.EmptyView>
            </CollectionView>
            <Grid ColumnDefinitions="*,*" ColumnSpacing="5">
                <Button Text="Save as Template" BackgroundColor="#8E44AD" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="8" Clicked="OnSaveTemplateClicked" />
                <Button Text="Delete Template" BackgroundColor="#E74C3C" TextColor="White" FontAttributes="Bold" HeightRequest="40" CornerRadius="8" Clicked="OnDeleteTemplateClicked" Grid.Column="1" />
            </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
